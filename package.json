{
	"name": "portal.morgantondayschool-com",
	"version": "1.0.0",
	"description": "MDS Parent Portal",
	"main": "public/scripts/index.js",
	"scripts": {
		"build-scripts": "esbuild src/scripts/index.js --bundle --minify --sourcemap --outfile=public/scripts/index.js",
		"build-styles": "sass --style compressed src/styles/index.scss public/styles/index.css",
		"build": "npm run build-scripts && npm run build-styles",
		"watch-scripts": "esbuild src/scripts/index.js --bundle --watch --sourcemap --outfile=public/scripts/index.js",
		"watch-styles": "sass --watch src/styles/index.scss public/styles/index.css"
	},
	"author": "brasstacksweb",
	"license": "ISC",
	"devDependencies": {
		"concurrently": "^8.2.2",
		"esbuild": "^0.12.20",
		"eslint-config-airbnb-base": "^15.0.0",
		"sass": "^1.96.0",
		"stylelint": "^16.26.1",
		"stylelint-order": "^6.0.4"
	}
}
