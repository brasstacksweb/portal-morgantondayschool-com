{% if not currentUser %}
	{% redirect 'login' %}
{% endif %}

{% set error = craft.app.getSession().getFlash('error') %}
{% set success = craft.app.getSession().getFlash('success') %}

{% set heading = 'Welcome' %}
{% set body = error ?? success ?? 'Select your children\'s classes to receive updates.' %}
{% set subscribedClasses = craft.subscriptions.getSubscribedClasses(currentUser.id) %}

{% extends '_layouts/html' %}

{% set loadForm = true %}

{% block content %}
	<article>
		<section>
			{% include '_components/subscriptions' with {
				heading: heading,
				body: body,
				form: create({
					class: 'modules\\notifications\\models\\Subscriptions',
					classes: subscribedClasses|map(c => c.id),
				}),
				hasError: error is not null,
			} only %}
		</section>
	</article>
{% endblock %}
