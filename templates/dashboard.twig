{% if not currentUser.hasOnboarded %}
	{% redirect 'onboarding' %}
{% endif %}

{% extends '_layouts/html' %}

{% block content %}
	<article>
		<header class="dashboard-header">
			<h1>Updates</h1>
			<div data-comp-name="NotificationBadge">
				<span class="badge" style="display: none;">0</span>
			</div>
		</header>

		{% if unreadUpdates|length > 0 %}
			<div class="updates-section">
				<h2>Unread Updates</h2>
				<div data-comp-name="UpdatesList">
					{% for update in unreadUpdates %}
						<article class="update-item" data-update-id="{{ update.id }}">
							<div class="update-header">
								{% set relatedClass = update.class.one() %}
								{% if relatedClass %}
									<span class="class-name">{{ relatedClass.title }}</span>
								{% endif %}
								<time datetime="{{ update.postDate|date('c') }}">
									{{ update.postDate|date('M j, Y') }}
								</time>
							</div>
							<h3>{{ update.title }}</h3>
							<div class="update-content">
								{{ update.content }}
							</div>
						</article>
					{% endfor %}
				</div>
			</div>
		{% endif %}

		<div class="updates-section">
			<h2>Recent Updates</h2>
			{% if recentUpdates|length > 0 %}
				{% for update in recentUpdates %}
					<article class="update-item read" data-update-id="{{ update.id }}">
						<div class="update-header">
							{% set relatedClass = update.class.one() %}
							{% if relatedClass %}
								<span class="class-name">{{ relatedClass.title }}</span>
							{% endif %}
							<time datetime="{{ update.postDate|date('c') }}">
								{{ update.postDate|date('M j, Y') }}
							</time>
						</div>
						<h3>{{ update.title }}</h3>
						<div class="update-content">
							{{ update.content }}
						</div>
					</article>
				{% endfor %}
			{% else %}
				<p>No updates yet. Updates from your subscribed classes will appear here.</p>
			{% endif %}
		</div>
	</article>
{% endblock %}
