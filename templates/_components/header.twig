{##
 # Header component
 # @param {object} logo
 # @param {object[]} navLinks
 # @param {object[]} iconLinks
 # @param {object} cta
 #}

{# Params #}
{% set logo = logo ?? null %}
{% set navLinks = navLinks ?? [] %}
{% set iconLinks = iconLinks ?? [] %}
{% set cta = cta ?? null %}

{# Variables #}
{% set handle = 'header' %}

{# Markup #}
{% import '_icons' as icons %}

<div class="{{ handle }}">
	<input type="checkbox" id="nav-toggle" style="display: none" />
	<a href="{{ siteUrl }}" title="Home">
		{% if logo %}
			{{ logo.render() }}
		{% else %}
			TITAN<br />LINK</a>
		{% endif %}
	</a>
	<nav>
		<ul>
			{% for l in navLinks %}
				<li>
					{% switch l.type.handle %}
						{% case 'dropdown' %}
							<input type="checkbox" id="{{ l.title|kebab }}" style="display:none;" />
							<label for="{{ l.title|kebab }}">
								{{ l.title }}
								{{ icons.chevron }}
							</label>
							<ul>
								{% for ll in l.navLinks %}
									<li>{{ ll.render({ type: 'tertiary', size: 'sm' }) }}</li>
								{% endfor %}
							</ul>
						{% default %}
							{{ l.render({ type: 'tertiary', size: 'sm' }) }}
					{% endswitch %}
				</li>
			{% endfor %}
		</ul>
	</nav>
	{% if iconLinks is not empty %}
		<aside>
			{% for l in iconLinks %}
				{{ l.render() }}
			{% endfor %}
			{% if currentUser and currentUser.isAdmin %}
				<a href="/subscriptions" title="Notifications" aria-label="Notifications">
					{{ icons.bell() }}
				</a>
			{% endif %}
		</aside>
	{% endif %}
	{% if cta %}
		{{ cta.render() }}
	{% endif %}
	<label for="nav-toggle">
		<i aria-hidden="true"></i>
		<i aria-hidden="true"></i>
	</label>
</div>
