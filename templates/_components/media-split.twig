{##
 # Media Split component
 # @param {string} heading
 # @param {string} subheading
 # @param {HTML} body
 # @param {object} cta
 # @param {object} image
 # @param {string} alignment <top, center*, bottom>
 # @param {string} mediaPosition <left*, right>
 # @param {string} backgroundColor
 #}

{# Params #}
{% set heading = heading ?? '' %}
{% set subheading = subheading ?? '' %}
{% set body = body ?? '' %}
{% set cta = cta ?? null %}
{% set image = image ?? null %}
{% set alignment = alignment ?? 'center' %}
{% set mediaPosition = mediaPosition ?? 'left' %}
{% set backgroundColor = backgroundColor ?? '' %}

{# Variables #}
{% set handle = 'media-split' %}

{# Markup #}
<div class="
		{{ handle }}
		{{ handle }}--alignment-{{ alignment }}
		{{ handle }}--media-position-{{ mediaPosition }}
	"
	style="--bg-color: var(--c-{{ backgroundColor }}-lt)">
	{% if image %}
		{{ image.render({ type: 'figure' }) }}
	{% endif %}
	<header>
		<h2>{{ heading }}</h2>
		{% if subheading is not empty %}
			<h3>{{ subheading }}</h3>
		{% endif %}
		{% if body is not empty %}
			<div>{{ body }}</div>
		{% endif %}
		{% if cta %}
			<nav>
				{{ cta.render({ type: 'tertiary' }) }}
			</nav>
		{% endif %}
	</header>
</div>
