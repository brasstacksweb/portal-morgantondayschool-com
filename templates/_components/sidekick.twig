{##
 # Sidekick component
 # @param {string} heading
 # @param {HTML} body
 # @param {modules\components\models\Cta} cta
 # @param {object} image
 # @param {string} textPosition <left*, right>
 # @param {bool} invertTextColor
 #}

{# Params #}
{% set heading = heading ?? '' %}
{% set body = body ?? [] %}
{% set cta = cta ?? null %}
{% set image = image ?? null %}
{% set textPosition = textPosition ?? 'left' %}
{% set invertTextColor = invertTextColor ?? false %}

{# Variables #}
{% set handle = 'sidekick' %}

{# Markup #}
<div class="
	{{ handle }}
	{{ handle }}--text-pos-{{ textPosition }}
	{{ invertTextColor ? handle ~ '--invert-text-color' }}
">
	{% if image %}
		{% include '_components/background-image' with { image: image } %}
		<div></div>
	{% endif %}

	<header>
		{% include '_components/text-block' with {
			heading: heading,
			body: body,
			cta: cta,
			invert: not invertTextColor,
		} only %}
	</header>
</div>
