{##
 # Primary Hero component
 # @param {string} heading
 # @param {string} subheading
 # @param {HTML} body
 # @param {object} person
 # |_@param {string} title
 # |_@param {object} image
 # @param {object[]} ctas
 # @param {object} image
 # @param {string} backgroundColor
 #}

{# Params #}
{% set heading = heading ?? '' %}
{% set subheading = subheading ?? '' %}
{% set body = body ?? '' %}
{% set person = person ?? null %}
{% set ctas = ctas ?? [] %}
{% set image = image ?? null %}
{% set backgroundColor = backgroundColor ?? '' %}

{# Variables #}
{% set handle = 'hero' %}

{# Markup #}
<div class="{{ handle }}" style="--bg-color: var(--c-{{ backgroundColor }}-lt)">
	{% if image %}
		{{ image.render({ type: 'figure', transform: 'hero' }) }}
	{% endif %}
	<div>
		<h1>{{ heading }}</h1>
		{% if subheading is not empty %}
			<h2>
				{{ subheading }}
			</h2>
		{% endif %}
		{% if person %}
			<h3>
				<em>{{ person.image.render({ transform: 'avatar' }) }}</em>
				<span>{{ person.title }}</span>
			</h3>
		{% endif%}
		{% if body is not empty %}
			<div>{{ body }}</div>
		{% endif %}
		{% if ctas is not empty %}
			<nav>
				{% for c in ctas %}
					{{ c.render({ type: loop.first ? 'primary' : 'secondary' }) }}
				{% endfor %}
			</nav>
		{% endif %}
	</div>
</div>
