{% set content = content ?? '' %}
{% set type = type ?? 'primary' %}
{% set size = size ?? 'md' %}
{% set invert = invert ?? false %}

{% set url = entry.document[0].url ?? siteUrl %}

<a href="{{ url }}" target="_blank" rel="noopener noreferrer" title="{{ entry.title }}">
	{% if content is not empty %}
		{{ content }}
	{% else %}
		{% include '_components/cta' with {
			title: entry.title,
			type: type,
			size: size,
			invert: invert,
		} only %}
	{% endif %}
</a>
