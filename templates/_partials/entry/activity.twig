{% set eagerLoad = eagerLoad ?? false %}

{% include '_components/card' with {
	image: entry.previewImage[0] ?? null,
	heading: entry.title,
	body: entry.previewText,
	cta: create({
		class: 'craft\\elements\\Entry',
		typeId: craft.app.entries.getEntryTypeByHandle('pageCta').id,
		fieldId: 6,
		title: 'View Activity',
		page: [entry.id],
	}),
	eagerLoad: eagerLoad,
} only %}
