{% set type = type ?? 'primary' %}
{% set size = size ?? 'md' %}
{% set invert = invert ?? false %}

<a href="{{ entry.referenceUrl }}" target="_blank" rel="noopener noreferrer" title="entry.title">
	{% include '_components/cta' with {
		title: entry.title,
		type: type,
		size: size,
		invert: invert,
	} only %}
</a>
