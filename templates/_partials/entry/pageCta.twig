{% set type = type ?? 'primary' %}
{% set size = size ?? 'md' %}
{% set invert = invert ?? false %}

{% set url = entry.page[0].url ?? '' %}

{% if entry.anchor is not empty %}
	{% set url = url ~ '#' ~ entry.anchor %}
{% endif %}

<a href="{{ url }}" title="{{ entry.title }}">
	{% include '_components/text-cta' with {
		title: entry.title,
		type: type,
		size: size,
		invert: invert,
	} only %}
</a>
