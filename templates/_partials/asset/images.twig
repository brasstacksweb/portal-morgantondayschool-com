{% set type = type ?? '' %}
{% set transform = transform ?? '' %}

{% switch type %}
{% case 'background' %}
	{% include '_components/background-image' with {
		url: transform ? asset.getUrl(transform) : asset.url,
		fit: asset.fit.value ?? 'cover',
		position: asset.position.value ?? 'center',
		video: asset.video[0] ?? null,
		mobileImage: asset.mobileImage[0] ?? null,
	} only %}
{% case 'figure' %}
	{% include '_components/figure' with {
		title: asset.title,
		url: transform ? asset.getUrl(transform) : asset.url,
		fit: asset.fit.value ?? 'cover',
		position: asset.position.value ?? 'center',
		alt: asset.alt,
		caption: asset.caption,
		video: asset.video[0] ?? null,
	} only %}
{% default %}
	<img
		src="{{ transform ? asset.getUrl(transform) : asset.url }}"
		alt="{{ asset.caption ?? asset.alt ?? asset.title }}" />
{% endswitch %}
