<button type="button"
		class="btn custom-action-btn"
		data-entry-id="{{ entryId ?? '' }}"
		onclick="handlePushNotification(this)">
	{{ buttonLabel }}
</button>

{% js %}
function handlePushNotification(button) {
    const entryId = button.getAttribute('data-entry-id');

    if (!entryId) {
        Craft.cp.displayError('Entry must be saved first.');
        return;
    }

    button.disabled = true;

    // Make AJAX request to your custom action
    Craft.sendActionRequest('POST', '{{ actionUrl }}', {
        data: {
            entryId: entryId
        }
    })
    .then(response => {
        Craft.cp.displayNotice(response.data.message || 'Action completed successfully');
    })
    .catch(error => {
        Craft.cp.displayError(error.response?.data?.message || 'An error occurred');
    })
}
{% endjs %}
