{##
 # Activity entry
 # @param {Entry} entry
 #}

{# Params #}
{% set entry = craft.entries.id(entry.id).with([
	'heroImage',
	'cta.pageCta:page',
	'activityModules.accordionList:accordions.textBlock:cta.pageCta:page',
	'activityModules.cardList:cards.card:image',
	'activityModules.cardList:cards.card:cta.pageCta:page',
	'activityModules.mediaSplit:image',
	'activityModules.mediaSplit:cta.pageCta:page',
	'activityModules.textList:textlist.textBlock:cta.pageCta:page',
]).one() %}

{# Markup #}
{% set metaTitle = entry.heading ?? entry.title ?? '' %}
{% set metaDescription = entry.overview|striptags[:160] %}

{% extends '_layouts/html' %}

{% block content %}
	<article>
		<header>
			{% include '_components/hero' with {
				image: entry.heroImage[0] ?? null,
				heading: entry.heading,
				subheading: entry.date,
				body: entry.overview,
				ctas: entry.cta,
				backgroundColor: 'violet',
			} only %}
		</header>

		{% for m in entry.activityModules %}
			{{ m.render() }}
		{% endfor %}
	</article>
{% endblock %}
