{##
 # Activity entry
 # @param {Entry} entry
 #}

{# Params #}
{% set heroImage = entry.heroImage.one() %}
{% set ctas = entry.ctas.with([
	'pageCta:page',
]).all() %}
{% set activityModules = entry.activityModules.with([
	'accordionList:accordions.textBlock:cta.pageCta:page',
	'cardList:cards.card:image',
	'cardList:cards.card:cta.pageCta:page',
	'media:image',
	'mediaSplit:image',
	'mediaSplit:cta.pageCta:page',
	'textList:textlist.textBlock:cta.pageCta:page',
]).all() %}

{# Markup #}
{% set metaTitle = entry.heading ?? entry.title ?? '' %}
{% set metaDescription = entry.overview|striptags[:160] %}
{% set metaNoIndex = true %}

{% extends '_layouts/html' %}

{% block content %}
	{% cache if not devMode %}
		<article>
			<header>
				{% include '_components/hero' with {
					image: heroImage,
					heading: entry.heading,
					subheading: entry.date,
					body: entry.overview,
					ctas: ctas,
					backgroundColor: 'violet',
				} only %}
			</header>

			{% for m in activityModules %}
				{{ m.render() }}
			{% endfor %}
		</article>
	{% endcache %}
{% endblock %}
